{
  "connectType": "S3",
  "options": {
    "warehouse": "s3a://bucket/paimon/test-data",
    "catalogType": "filesystem",
    "database": "nimbus_bigdata_lzk_2",
    "endpoint": "http://127.0.0.1:9000",
    "region": "us-east-1",
    "pathStyleAccess": true,
    "sslEnabled": false
  },
  "table": "peopletest",
  "loadMode": "APPEND",
  "write": {
    "batchSize": 1000,
    "overwritePartition": {
      "enabled": false,
      "partition": {}
    }
  },
  "primaryKey": "",
  "partitionKey": null,
  "column": [
    {
      "name": "name",
      "type": "string"
    },
    {
      "name": "age",
      "type": "int"
    }
  ],
  "sink": {
    "options": {
      "full-compaction.delta-commits": "1",
      "file.format": "parquet",
      "bucket": "1",
      "snapshot.num-retained.min": "5"
    }
  }
}
